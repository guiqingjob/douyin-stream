# Qwen 转写环境变量配置
# 复制为 .env 并填写实际值

# 基础 URL
QWEN_BASE_URL=https://www.qianwen.com
QWEN_APP_URL=${QWEN_BASE_URL}/discover

# 认证状态文件路径
QWEN_AUTH_STATE_PATH=.auth/qwen-storage-state.json

# 账号配置文件路径
QWEN_ACCOUNTS_FILE=config/transcribe/accounts.json
QWEN_ACCOUNT_POOL_STATE_FILE=.auth/account-pool-state.json
QWEN_QUOTA_STATE_FILE=.auth/quota-usage.json

# 默认账号
QWEN_ACCOUNT=
QWEN_ACCOUNT_STRATEGY=round-robin

# 导出设置
QWEN_EXPORT_FORMAT=md
QWEN_DELETE_AFTER_EXPORT=false
QWEN_SAVE_DEBUG_JSON=false

# 并发和重试
QWEN_EXPORT_CONCURRENCY=2
QWEN_EXPORT_MAX_RETRIES=6
QWEN_EXPORT_INITIAL_BACKOFF_SECONDS=2.0

# 下载目录
QWEN_DOWNLOAD_DIR=transcripts

# 网络日志
QWEN_NETWORK_LOG_DIR=artifacts/network

# Pipeline 设置
PIPELINE_EXPORT_FORMAT=md
PIPELINE_OUTPUT_DIR=./transcripts/
PIPELINE_DELETE_AFTER_EXPORT=false
PIPELINE_REMOVE_VIDEO=false
PIPELINE_KEEP_ORIGINAL=true
PIPELINE_CONCURRENCY=1
